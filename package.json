{
  "name": "email-file-uploader",
  "version": "1.0.0",
  "description": "React component for uploading .msg and .pdf files with automatic MSG-to-PDF conversion",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run --component",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "1.28.0",
    "dompurify": "3.4.1",
    "html2canvas": "1.4.1",
    "jspdf": "2.5.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "14.4.1"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.3.5",
    "@types/dompurify": "3.0.5",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "cypress": "14.5.4",
    "eslint": "^9.39.4",
    "jsdom": "26.1.0",
    "prettier": "^3.8.3",
    "storybook": "10.3.5",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vite-plugin-node-polyfills": "0.26.0",
    "vitest": "3.2.4"
  }
}
